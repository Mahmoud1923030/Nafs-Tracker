/*
  # ── Security Headers ──────────────────────────────────────────────
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(self), microphone=(), camera=(), payment=()
  X-XSS-Protection: 1; mode=block

  # ── Content Security Policy ───────────────────────────────────────
  # Allows Firebase, Google Fonts, Font Awesome, Chart.js, Aladhan API,
  # Quran APIs, and Hadith CDN.  Blocks everything else.
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://apis.google.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' https://fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data: https://lh3.googleusercontent.com https://*.googleapis.com; connect-src 'self' https://firestore.googleapis.com https://www.googleapis.com https://securetoken.googleapis.com https://identitytoolkit.googleapis.com https://api.aladhan.com https://api.alquran.cloud https://cdn.islamic.network https://cdn.jsdelivr.net https://verses.quran.com https://equran.me; media-src 'self' https://cdn.islamic.network https://download.quranicaudio.com https://server6.mp3quran.net https://server8.mp3quran.net https://server10.mp3quran.net https://server11.mp3quran.net https://server12.mp3quran.net https://server13.mp3quran.net https://server16.mp3quran.net https://ia800207.us.archive.org https://ia803104.us.archive.org https://ia600301.us.archive.org; frame-src https://accounts.google.com https://*.firebaseapp.com; object-src 'none'; base-uri 'self'; form-action 'self'

  # ── Cache control for static assets ───────────────────────────────
/styles-tw.css
  Cache-Control: public, max-age=31536000, immutable

/styles.css
  Cache-Control: public, max-age=31536000, immutable

/app.js
  Cache-Control: public, max-age=0, must-revalidate

/sw.js
  Cache-Control: public, max-age=0, must-revalidate

/manifest.json
  Cache-Control: public, max-age=86400
