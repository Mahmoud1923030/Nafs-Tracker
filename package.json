{
  "name": "nafs-tracker",
  "version": "1.0.0",
  "description": "Nafs Tracker - تطبيق متابعة العبادات اليومية",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./styles-tw.css --minify",
    "build:js": "npx terser app.js -o app.min.js -c -m",
    "build": "npm run build:css && npm run build:js",
    "dev": "npx serve .",
    "deploy:vercel": "vercel --prod",
    "deploy:firebase": "firebase deploy"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.19",
    "terser": "^5.36.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}